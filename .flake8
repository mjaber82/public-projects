[flake8]
max-line-length = 119
extend-ignore = E203, W503, E501, W292, W291, F403, F405
exclude =
    .git,
    __pycache__,
    migrations,
    venv,
    .venv,
    .env,
    db.sqlite3
per-file-ignores =
    __init__.py:F401
    app/settings/*.py:F403,F405
    app/settings/prod.py:E402
    app/*/admin.py:F401
    app/*/tests.py:F401
    app/*/views.py:F401
    app/core/decorators.py:F401
